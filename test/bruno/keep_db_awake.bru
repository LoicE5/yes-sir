meta {
  name: Keep DB Awake (Cron)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/cronjobs/keep_db_awake
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{cronSecret}}
}

vars:pre-request {
  cronSecret: example
}

tests {
  test("status is not 401 when correct auth provided", function() {
    expect(res.status).to.not.equal(401)
  })
  
  test("status is 200 or 500 (authenticated request)", function() {
    expect([200, 500]).to.include(res.status)
  })
  
  test("response contains message field", function() {
    expect(res.body).to.have.property("message")
  })
  
  test("message contains keep db awake text on success", function() {
    if (res.status === 200) {
      expect(res.body.message).to.include("Keep DB awake")
    }
  })
  
  test("response contains results object on authenticated request", function() {
    if (res.status !== 401) {
      expect(res.body).to.have.property("results")
      expect(res.body.results).to.have.property("anon_read")
      expect(res.body.results).to.have.property("anon_write")
      expect(res.body.results).to.have.property("service_read")
      expect(res.body.results).to.have.property("service_write")
    }
  })
  
  test("all results are ok on success", function() {
    if (res.status === 200 && res.body.results) {
      expect(res.body.results.anon_read).to.equal("ok")
      expect(res.body.results.anon_write).to.equal("ok")
      expect(res.body.results.service_read).to.equal("ok")
      expect(res.body.results.service_write).to.equal("ok")
    }
  })
}
