meta {
  name: Generate Code
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/generate_code?class_name=MathClass&time_given=5
  body: none
  auth: none
}

tests {
  test("status is 201 on success", function() {
    expect(res.status).to.equal(201)
  })

  test("response contains code field", function() {
    expect(res.body).to.have.property("code")
  })

  test("code is a number between 1 and 999999", function() {
    expect(res.body.code).to.be.a("number")
    expect(res.body.code).to.be.at.least(1)
    expect(res.body.code).to.be.at.most(999999)
  })

  test("response contains js_time field", function() {
    expect(res.body).to.have.property("js_time")
    expect(res.body.js_time).to.be.a("number")
  })

  test("response contains js_expiry field", function() {
    expect(res.body).to.have.property("js_expiry")
    expect(res.body.js_expiry).to.be.a("number")
  })

  test("js_expiry is greater than js_time", function() {
    expect(res.body.js_expiry).to.be.greaterThan(res.body.js_time)
  })
}
